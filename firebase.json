{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "source": ".",
    "frameworksBackend": {
      "region": "us-central1",
      "environmentVariables": {
        "GEMINI_API_KEY": "SECRET:GEMINI_API_KEY",
        "CAL_WEBHOOK_SECRET": "SECRET:CAL_WEBHOOK_SECRET"
      }
    },
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  }
}
